{
  "listeners": [
    {
      "address": "0.0.0.0",
      "port": 8080
    }
  ],
  "db_clients": [
    {
      "name": "default",
      "rdbms": "postgresql",
      "host": "${DB_HOST}",
      "port": 5432,
      "dbname": "${DB_NAME}",
      "user": "${DB_USER}",
      "passwd": "${DB_PASSWORD}",
      "is_fast": false,
      "connection_number": 8
    }
  ],
  "custom_config": {
    "threads_num": 0,
    "local_ai": {
      "python_bin": "tools/ai_project_manager/.conda/bin/python",
      "script_path": "tools/ai_project_manager/scripts/generate_once.py",
      "model_dir": "tools/ai_project_manager/models/mt5-small-offline"
    }
  }
}
