@baseUrl = http://127.0.0.1
@adminUsername = admin
@password = 123456
@employeeUsername = chen_xu

### ==========================================
### 1. 管理员登录
### ==========================================
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

> {%
client.test("管理员登录成功", function() {
    client.assert(response.status === 200, "状态码应为 200");
});
%}

### ==========================================
### 2. 创建临时项目与阶段节点
### ==========================================
### 创建临时项目
< {%
  var rand = Math.floor(Math.random() * 1000000);
  request.variables.set("projectName", "task_test_project_" + rand);
%}
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{projectName}}",
  "description": "任务模块测试项目。",
  "planned_start_date": "2026-04-01",
  "planned_end_date": "2026-04-30"
}

> {%
client.global.set("tempProjectId", response.body.data.id);
%}

### 创建阶段节点
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes
Content-Type: application/json

{
  "name": "开发设计与编码",
  "description": "系统设计与核心开发阶段",
  "planned_start_date": "2026-04-05",
  "planned_end_date": "2026-04-20"
}

> {%
client.global.set("tempNodeId", response.body.data.id);
%}

### ==========================================
### 3. 创建子任务与参数校验
### ==========================================
### 正常创建子任务 (未传负责人，默认归属于项目负责人且 priority=2)
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{tempNodeId}}/subtasks
Content-Type: application/json

{
  "name": "数据库设计",
  "description": "主表与关系表设计",
  "planned_start_date": "2026-04-06",
  "planned_end_date": "2026-04-10"
}

> {%
client.test("正常创建子任务成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 0);
    client.assert(response.body.data.priority === 2, "默认优先级应为 2");
    client.global.set("tempTaskId", response.body.data.id);
});
%}

### 异常：子任务时间区间超出阶段节点范围，预期 409
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{tempNodeId}}/subtasks
Content-Type: application/json

{
  "name": "越界任务",
  "planned_start_date": "2026-04-03",
  "planned_end_date": "2026-04-10"
}

> {%
client.test("子任务时间超出阶段范围报错 409", function() {
    client.assert(response.status === 409);
});
%}

### ==========================================
### 4. 获取子任务详情与列表
### ==========================================
### 获取详情
GET {{baseUrl}}/api/subtasks/{{tempTaskId}}

> {%
client.test("获取子任务详情成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.id === parseInt(client.global.get("tempTaskId")));
});
%}

### 获取节点下的子任务列表
GET {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{tempNodeId}}/subtasks

> {%
client.test("获取节点下的任务列表成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.length === 1);
});
%}

### ==========================================
### 5. 修改子任务基础信息
### ==========================================
PATCH {{baseUrl}}/api/subtasks/{{tempTaskId}}
Content-Type: application/json

{
  "name": "数据库设计与物理模型建立",
  "description": "进行主表结构优化",
  "priority": 3,
  "planned_start_date": "2026-04-07",
  "planned_end_date": "2026-04-10"
}

> {%
client.test("修改子任务成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.priority === 3);
});
%}

### ==========================================
### 6. 子任务进度与状态流程控制
### ==========================================
### 手动开始子任务 (状态由 1 变更为 2，添加默认记录)
POST {{baseUrl}}/api/subtasks/{{tempTaskId}}/start
Content-Type: application/json

{
  "progress_note": "开始着手数据库表结构详细设计"
}

> {%
client.test("手动开始子任务成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.subtask.status === 2, "状态应变更为 2");
});
%}

### 提交中间阶段进度 (例如 50%)
POST {{baseUrl}}/api/subtasks/{{tempTaskId}}/progress
Content-Type: application/json

{
  "progress_percent": 50,
  "progress_note": "已完成核心关系表的物理模型建立"
}

> {%
client.test("提交中间进度成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.subtask.progress_percent === 50);
});
%}

### 获取子任务进度推进历史列表
GET {{baseUrl}}/api/subtasks/{{tempTaskId}}/progress

> {%
client.test("获取进度推进记录成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.list.length >= 2, "当前应至少有开始和50%这两条记录");
});
%}

### 提交 100% 进度自动完成子任务 (状态应变为 3)
POST {{baseUrl}}/api/subtasks/{{tempTaskId}}/progress
Content-Type: application/json

{
  "progress_percent": 100,
  "progress_note": "所有建表 SQL 已编写，审核完成"
}

> {%
client.test("自动完成子任务成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.subtask.status === 3, "状态应自动变更为 3 (已完成)");
});
%}

### 撤销子任务完成状态 (状态应恢复为 2，进度恢复至前一次的 50%)
POST {{baseUrl}}/api/subtasks/{{tempTaskId}}/reopen
Content-Type: application/json

{}

> {%
client.test("撤销完成成功并自动恢复上一节点状态", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.status === 2);
    client.assert(response.body.data.progress_percent === 50, "进度应恢复至 50");
});
%}

### ==========================================
### 7. 获取当前登录用户负责的任务列表 (My Tasks)
### ==========================================
GET {{baseUrl}}/api/my/subtasks

> {%
client.test("获取当前用户负责的任务列表成功", function() {
    client.assert(response.status === 200);
});
%}

### ==========================================
### 8. 删除子任务与越权拦截测试
### ==========================================
### 管理员登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 普通员工登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

### 越权尝试：普通员工删除非本人负责项目的子任务，预期 403
DELETE {{baseUrl}}/api/subtasks/{{tempTaskId}}

> {%
client.test("越权删除子任务被拦截", function() {
    client.assert(response.status === 403);
});
%}

### 普通员工登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 重新登录管理员
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 删除临时子任务
DELETE {{baseUrl}}/api/subtasks/{{tempTaskId}}

> {%
client.test("删除子任务成功", function() {
    client.assert(response.status === 200);
});
%}

### ==========================================
### 9. 数据闭环清理
### ==========================================
### 删除新建项目，级联清理所有数据
DELETE {{baseUrl}}/api/projects/{{tempProjectId}}

> {%
client.test("项目删除成功，环境清理完毕", function() {
    client.assert(response.status === 200);
});
%}
