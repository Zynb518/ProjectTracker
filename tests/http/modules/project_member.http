### 查询禁用用户 ID
GET {{baseUrl}}/api/users?keyword={{disabledUsername}}&status=2&page=1&page_size=10

> {%
client.test("管理员查询禁用用户成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    var disabledUser = response.body.data.list.find(function(item) {
        return item.username === "zhao_yue";
    });
    client.assert(disabledUser !== undefined, "用户列表应包含禁用用户 zhao_yue");
    client.assert(disabledUser.status === 2, "zhao_yue 应为禁用状态");
    client.global.set("disabledUserId", disabledUser.id);
});
%}

### 禁用用户不会出现在候选列表
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members/candidates?keyword={{disabledUsername}}&page=1&page_size=10

> {%
client.test("禁用用户被候选列表排除", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.total === 0, "禁用用户筛选结果 total 应为 0");
    client.assert(response.body.data.list.length === 0, "禁用用户筛选结果应为空");
});
%}

### 候选列表分页
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members/candidates?page=1&page_size=1

> {%
client.test("候选列表分页参数生效", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.data.page === 1, "page 应为 1");
    client.assert(response.body.data.page_size === 1, "page_size 应为 1");
    client.assert(response.body.data.list.length <= 1, "当前页最多返回一个候选人");
});
%}

