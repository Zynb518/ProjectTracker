### 项目经理负责人查看成员列表
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members

> {%
client.test("项目经理负责人查看成员列表成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    var manager = response.body.data.list.find(function(item) {
        return item.user_id === parseInt(client.global.get("managerUserId"));
    });
    var admin = response.body.data.list.find(function(item) {
        return item.user_id === parseInt(client.global.get("adminUserId"));
    });
    client.assert(manager !== undefined && manager.is_owner === true, "wang_jie 应为当前负责人");
    client.assert(admin !== undefined && admin.is_owner === false, "管理员不再是负责人但仍是项目成员");
});
%}

