### 3. 普通员工登录并创建个人项目
< {%
  var o3 = Math.floor(Math.random() * 200) + 1;
  var o4 = Math.floor(Math.random() * 250) + 1;
  request.variables.set("loginIp", "172.50." + o3 + "." + o4);
%}
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{loginIp}}

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

> {%
client.test("普通员工登录成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.user.system_role === 3, "预期普通员工角色");
    client.global.set("employeeUserId", response.body.data.user.id);
});
%}

### 普通员工创建个人项目
< {%
  var rand = Date.now() + "_" + Math.floor(Math.random() * 1000000);
  request.variables.set("personalProjectName", "project_member_personal_" + rand);
%}
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{personalProjectName}}",
  "description": "项目成员模块个人项目限制测试",
  "planned_start_date": "2026-12-01",
  "planned_end_date": "2026-12-31"
}

> {%
client.test("普通员工创建个人项目成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.owner_user_id === parseInt(client.global.get("employeeUserId")), "个人项目负责人应为创建人");
    client.global.set("personalProjectId", response.body.data.id);
});
%}

### 4. 普通员工个人项目成员权限
GET {{baseUrl}}/api/projects/{{personalProjectId}}/members

> {%
client.test("普通员工可以查看自己个人项目的成员列表", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.list.length === 1, "个人项目应只有创建人一个成员");
    var owner = response.body.data.list[0];
    client.assert(owner.user_id === parseInt(client.global.get("employeeUserId")), "成员应为当前普通员工");
    client.assert(owner.is_owner === true, "当前普通员工应为项目负责人");
});
%}

