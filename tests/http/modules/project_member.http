    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.owner_user_id === parseInt(client.global.get("adminUserId")), "初始负责人应为管理员");
    client.global.set("managedProjectId", response.body.data.id);
});
