### 9. 初始成员列表与候选人列表
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members

> {%
client.test("新项目初始成员列表只有管理员", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.list.length === 1, "新项目应只有一个初始成员");
    var owner = response.body.data.list[0];
    client.assert(owner.user_id === parseInt(client.global.get("adminUserId")), "初始成员应为管理员");
    client.assert(owner.username === "admin", "初始成员用户名应为 admin");
    client.assert(owner.is_owner === true, "管理员应为项目负责人");
    client.assert(typeof owner.joined_at === "string" && owner.joined_at.length > 0, "joined_at 应为非空字符串");
});
%}

### 获取默认候选列表
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members/candidates?page=1&page_size=10

> {%
client.test("管理员获取成员候选列表成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(Array.isArray(response.body.data.list), "list 应为数组");
    client.assert(response.body.data.total >= response.body.data.list.length, "total 不应小于当前页数量");
    client.assert(response.body.data.page === 1, "page 应为 1");
    client.assert(response.body.data.page_size === 10, "page_size 应为 10");
    for (var i = 0; i < response.body.data.list.length; i++) {
        var item = response.body.data.list[i];
        client.assert(item.id !== parseInt(client.global.get("adminUserId")), "候选列表不应包含现有管理员成员");
        client.assert(item.status === 1, "候选用户必须为启用状态");
    }
});
%}

### 按用户名查询项目经理 wang_jie
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members/candidates?keyword=wang_jie&page=1&page_size=10

> {%
client.test("候选列表包含 wang_jie", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    var candidate = null;
    for (var i = 0; i < response.body.data.list.length; i++) {
        if (response.body.data.list[i].username === "wang_jie") {
            candidate = response.body.data.list[i];
            break;
        }
    }
    client.assert(candidate !== null, "候选列表应包含 wang_jie");
    client.assert(candidate.system_role === 2, "wang_jie 应为项目经理");
    client.global.set("managerUserId", candidate.id);
});
%}

### 按用户名查询普通员工 chen_xu
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members/candidates?keyword=chen_xu&page=1&page_size=10

> {%
client.test("候选列表包含 chen_xu", function() {
    client.assert(response.status === 200, "预期状态码 200");
    var candidate = response.body.data.list.find(function(item) {
        return item.username === "chen_xu";
    });
    client.assert(candidate !== undefined, "候选列表应包含 chen_xu");
    client.assert(candidate.id === parseInt(client.global.get("employeeUserId")), "chen_xu ID 应与登录用户一致");
    client.assert(candidate.system_role === 3, "chen_xu 应为普通员工");
});
%}

