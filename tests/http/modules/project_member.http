### 13. 管理员查看添加后的成员与候选列表
GET {{baseUrl}}/api/projects/{{managedProjectId}}/members

> {%
client.test("成员列表包含管理员、项目经理和普通员工", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.list.length === 3, "成员列表应包含三个成员");
    var admin = response.body.data.list.find(function(item) { return item.user_id === parseInt(client.global.get("adminUserId")); });
    var manager = response.body.data.list.find(function(item) { return item.user_id === parseInt(client.global.get("managerUserId")); });
    var employee = response.body.data.list.find(function(item) { return item.user_id === parseInt(client.global.get("employeeUserId")); });
    client.assert(admin !== undefined && admin.is_owner === true, "管理员应为当前负责人");
    client.assert(manager !== undefined && manager.system_role === 2, "列表应包含项目经理");
    client.assert(employee !== undefined && employee.system_role === 3, "列表应包含普通员工");
});
%}

### 已添加成员不再出现在候选列表
