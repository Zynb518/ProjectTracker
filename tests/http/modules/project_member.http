GET {{baseUrl}}/api/projects/{{managedProjectId}}/members/candidates?keyword=li_ming&page=1&page_size=10

> {%
client.test("候选列表包含 li_ming", function() {
    client.assert(response.status === 200, "预期状态码 200");
    var candidate = response.body.data.list.find(function(item) {
        return item.username === "li_ming";
    });
