### 11. 节点列表、详情和甘特图查询
GET {{baseUrl}}/api/projects/{{managedProjectId}}/nodes

> {%
client.test("管理员获取节点列表成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.list.length === 3, "节点列表应包含三个节点");
    client.assert(response.body.data.list[0].id === parseInt(client.global.get("nodeId1")), "第一个节点 ID 应匹配");
    client.assert(response.body.data.list[0].sequence_no === 1, "第一个节点序号应为 1");
    client.assert(response.body.data.list[1].sequence_no === 2, "第二个节点序号应为 2");
    client.assert(response.body.data.list[2].sequence_no === 3, "第三个节点序号应为 3");
    for (var i = 0; i < response.body.data.list.length; i++) {
        client.assert(response.body.data.list[i].sub_task_count === 0, "初始节点子任务数量应为 0");
        client.assert(response.body.data.list[i].completed_sub_task_count === 0, "初始节点已完成子任务数量应为 0");
    }
});
%}

### 获取节点详情
GET {{baseUrl}}/api/projects/{{managedProjectId}}/nodes/{{nodeId1}}

> {%
client.test("管理员获取节点详情成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id === parseInt(client.global.get("nodeId1")), "节点 ID 应匹配");
    client.assert(response.body.data.project_id === parseInt(client.global.get("managedProjectId")), "项目 ID 应匹配");
    client.assert(response.body.data.name === "需求分析", "节点名称应匹配");
    client.assert(response.body.data.status === 1, "节点状态应为未开始");
    client.assert(response.body.data.completed_at === null, "未完成节点 completed_at 应为空");
});
%}

### 获取节点甘特图
GET {{baseUrl}}/api/projects/{{managedProjectId}}/nodes/{{nodeId1}}/gantt

> {%
client.test("管理员获取节点甘特图成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.project.id === parseInt(client.global.get("managedProjectId")), "甘特图项目 ID 应匹配");
    client.assert(response.body.data.node.id === parseInt(client.global.get("nodeId1")), "甘特图节点 ID 应匹配");
    client.assert(Array.isArray(response.body.data.subtasks), "subtasks 应为数组");
    client.assert(response.body.data.subtasks.length === 0, "当前节点应无子任务");
});
%}

