### 3. 普通员工登录并创建个人项目
< {%
  var o3 = Math.floor(Math.random() * 200) + 1;
  var o4 = Math.floor(Math.random() * 250) + 1;
  request.variables.set("loginIp", "172.70." + o3 + "." + o4);
%}
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{loginIp}}

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

> {%
client.test("普通员工登录成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.user.system_role === 3, "预期普通员工角色");
    client.global.set("employeeUserId", response.body.data.user.id);
});
%}

### 普通员工创建个人项目
< {%
  var rand = Date.now() + "_" + Math.floor(Math.random() * 1000000);
  request.variables.set("personalProjectName", "project_node_personal_" + rand);
%}
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{personalProjectName}}",
  "description": "阶段节点模块个人项目权限测试",
  "planned_start_date": "2026-12-01",
  "planned_end_date": "2026-12-31"
}

> {%
client.test("普通员工创建个人项目成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.owner_user_id === parseInt(client.global.get("employeeUserId")), "个人项目负责人应为创建人");
    client.global.set("personalProjectId", response.body.data.id);
});
%}

### 4. 普通员工负责人管理个人项目节点
POST {{baseUrl}}/api/projects/{{personalProjectId}}/nodes
Content-Type: application/json

{
  "name": "个人项目阶段",
  "description": "普通员工负责人创建的阶段节点",
  "planned_start_date": "2026-12-02",
  "planned_end_date": "2026-12-05"
}

> {%
client.test("普通员工负责人创建节点成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.project_id === parseInt(client.global.get("personalProjectId")), "项目 ID 应匹配");
    client.assert(response.body.data.sequence_no === 1, "第一个节点序号应为 1");
    client.assert(response.body.data.status === 1, "新节点状态应为未开始");
    client.global.set("personalNodeId", response.body.data.id);
});
%}

### 普通员工负责人查看个人项目节点列表
GET {{baseUrl}}/api/projects/{{personalProjectId}}/nodes

> {%
client.test("普通员工负责人查看个人项目节点列表成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.list.length === 1, "个人项目应有一个节点");
    client.assert(response.body.data.list[0].id === parseInt(client.global.get("personalNodeId")), "节点 ID 应匹配");
});
%}

