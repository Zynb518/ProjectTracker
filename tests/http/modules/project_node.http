### 查询项目经理 wang_jie 的用户 ID
GET {{baseUrl}}/api/users?keyword={{managerUsername}}&system_role=2&status=1&page=1&page_size=10

> {%
client.test("管理员查询项目经理成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    var manager = response.body.data.list.find(function(item) {
        return item.username === "wang_jie";
    });
    client.assert(manager !== undefined, "用户列表应包含 wang_jie");
    client.assert(manager.system_role === 2, "wang_jie 应为项目经理");
    client.global.set("managerUserId", manager.id);
});
%}

