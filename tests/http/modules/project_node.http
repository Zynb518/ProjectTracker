@baseUrl = http://127.0.0.1
@adminUsername = admin
@password = 123456
@employeeUsername = chen_xu

### ==========================================
### 1. 管理员登录
### ==========================================
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

> {%
client.test("管理员登录成功", function() {
    client.assert(response.status === 200, "状态码应为 200");
});
%}

### ==========================================
### 2. 创建临时项目
### ==========================================
< {%
  var rand = Math.floor(Math.random() * 1000000);
  request.variables.set("projectName", "project_node_test_" + rand);
%}
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{projectName}}",
  "description": "项目阶段节点模块测试项目。",
  "planned_start_date": "2026-04-01",
  "planned_end_date": "2026-04-30"
}

> {%
client.global.set("tempProjectId", response.body.data.id);
%}

### ==========================================
### 3. 创建阶段节点
### ==========================================
### 创建第一个阶段节点 (预期 sequence_no=1)
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes
Content-Type: application/json

{
  "name": "需求梳理",
  "description": "系统需求梳理阶段",
  "planned_start_date": "2026-04-02",
  "planned_end_date": "2026-04-05"
}

> {%
client.test("创建节点1成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.sequence_no === 1);
    client.global.set("nodeId1", response.body.data.id);
});
%}

### 创建第二个阶段节点 (预期 sequence_no=2)
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes
Content-Type: application/json

{
  "name": "架构设计",
  "description": "系统架构设计阶段",
  "planned_start_date": "2026-04-06",
  "planned_end_date": "2026-04-10"
}

> {%
client.test("创建节点2成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.sequence_no === 2);
    client.global.set("nodeId2", response.body.data.id);
});
%}

### 创建第三个阶段节点 (预期 sequence_no=3)
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes
Content-Type: application/json

{
  "name": "代码实现",
  "description": "系统编码实现阶段",
  "planned_start_date": "2026-04-11",
  "planned_end_date": "2026-04-20"
}

> {%
client.test("创建节点3成功", function() {
    client.assert(response.status === 200);
    client.global.set("nodeId3", response.body.data.id);
});
%}

### 异常：节点时间超出项目时间区间，预期 409
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes
Content-Type: application/json

{
  "name": "超出项目时间的节点",
  "planned_start_date": "2026-04-25",
  "planned_end_date": "2026-05-05"
}

> {%
client.test("节点超出项目日期范围报错 409", function() {
    client.assert(response.status === 409);
});
%}

### ==========================================
### 4. 获取阶段节点详情与列表
### ==========================================
### 获取详情
GET {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId1}}

> {%
client.test("获取阶段节点详情成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.id === parseInt(client.global.get("nodeId1")));
});
%}

### 获取阶段节点列表
GET {{baseUrl}}/api/projects/{{tempProjectId}}/nodes

> {%
client.test("获取节点列表成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.length === 3);
});
%}

### ==========================================
### 5. 修改阶段节点信息
### ==========================================
### 正常修改
PATCH {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId1}}
Content-Type: application/json

{
  "name": "需求梳理-联调更新",
  "description": "更新后的需求梳理描述",
  "planned_start_date": "2026-04-03",
  "planned_end_date": "2026-04-05"
}

> {%
client.test("更新节点基础信息成功", function() {
    client.assert(response.status === 200);
});
%}

### ==========================================
### 6. 调整阶段节点顺序 (Reorder)
### ==========================================
### 将顺序调整为: 节点 2 (第 1 位), 节点 1 (第 2 位), 节点 3 (第 3 位)
PUT {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/reorder
Content-Type: application/json

{
  "nodes": [
    {
      "node_id": {{nodeId2}},
      "sequence_no": 1
    },
    {
      "node_id": {{nodeId1}},
      "sequence_no": 2
    },
    {
      "node_id": {{nodeId3}},
      "sequence_no": 3
    }
  ]
}

> {%
client.test("调整阶段节点顺序成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.code === 0);
});
%}

### ==========================================
### 7. 阶段节点状态控制 (开始、完成、撤销)
### ==========================================
### 开始节点 2 (因为被排到了第一位，允许手动开始)
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId2}}/start
Content-Type: application/json

{}

> {%
client.test("手动开始节点成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.status === 2, "状态变更为 2 (进行中)");
});
%}

### 完成节点 2
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId2}}/complete
Content-Type: application/json

{}

> {%
client.test("手动完成节点成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.status === 3, "状态变更为 3 (已完成)");
});
%}

### 撤销完成节点 2
POST {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId2}}/reopen
Content-Type: application/json

{}

> {%
client.test("撤销完成节点成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.status === 2, "状态重新回到 2 (进行中)");
});
%}

### ==========================================
### 8. 获取节点子任务甘特图数据
### ==========================================
GET {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId1}}/gantt

> {%
client.test("获取阶段子任务甘特图成功", function() {
    client.assert(response.status === 200);
});
%}

### ==========================================
### 9. 删除阶段节点与边界越权测试
### ==========================================
### 管理员登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 普通员工登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

### 越权尝试：普通员工删除非本人负责项目的阶段节点，预期 403
DELETE {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId3}}

> {%
client.test("员工越权删除节点被拦截", function() {
    client.assert(response.status === 403);
});
%}

### 普通员工登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 重新登录管理员
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 删除第三个阶段节点
DELETE {{baseUrl}}/api/projects/{{tempProjectId}}/nodes/{{nodeId3}}

> {%
client.test("正常删除阶段节点成功", function() {
    client.assert(response.status === 200);
});
%}

### ==========================================
### 10. 数据闭环清理
### ==========================================
### 删除创建的新项目，级联清理所有数据
DELETE {{baseUrl}}/api/projects/{{tempProjectId}}

> {%
client.test("删除项目成功，环境清理完毕", function() {
    client.assert(response.status === 200);
});
%}
