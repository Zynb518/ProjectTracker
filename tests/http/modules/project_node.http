    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id === parseInt(client.global.get("nodeId2")), "节点 ID 应匹配");
    client.assert(response.body.data.status === 2, "节点状态应变为进行中");
    client.assert(response.body.data.completed_at === null, "进行中节点 completed_at 应为空");
});
%}

