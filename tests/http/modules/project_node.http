### 正常调整节点顺序为 2、1、3
PUT {{baseUrl}}/api/projects/{{managedProjectId}}/nodes/reorder
Content-Type: application/json

{
  "nodes": [
    {"node_id": {{nodeId2}}, "sequence_no": 1},
    {"node_id": {{nodeId1}}, "sequence_no": 2},
    {"node_id": {{nodeId3}}, "sequence_no": 3}
  ]
}

> {%
client.test("管理员调整节点顺序成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.project_id === parseInt(client.global.get("managedProjectId")), "项目 ID 应匹配");
    client.assert(response.body.data.nodes.length === 3, "应返回三个节点顺序");
    client.assert(response.body.data.nodes[0].node_id === parseInt(client.global.get("nodeId2")), "node2 应排在第一位");
    client.assert(response.body.data.nodes[0].sequence_no === 1, "node2 序号应为 1");
    client.assert(response.body.data.nodes[1].node_id === parseInt(client.global.get("nodeId1")), "node1 应排在第二位");
});
%}

