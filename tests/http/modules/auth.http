### 6. 用户 A 登录 (第 6 次，令牌不足，预期触发限流 429)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{testIp}}

{
  "username": "user_limit_a",
  "password": "wrong_password_a"
}

> {%
client.test("第6次请求触发限流", function() {
    client.assert(response.status === 429, "应触发限流返回 429");
    client.assert(response.body.message === "登录过于频繁，请稍后再试", "返回信息不符合提示");
});
%}
