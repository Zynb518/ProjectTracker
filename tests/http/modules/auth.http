@baseUrl = http://127.0.0.1
@username = admin
@password = 123456
@wrongPassword = wrong_password

### [正常路径] 1. 登录 (获取 Session Cookie)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{password}}"
}

> {%
client.test("登录成功", function() {
    client.assert(response.status === 200, "预期状态码 200，但实际是 " + response.status);
    client.assert(response.body.code === 0, "业务错误码预期为 0");
});
%}

### [正常路径] 2. 获取当前登录用户信息
GET {{baseUrl}}/api/auth/me

> {%
client.test("获取当前用户信息成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.data.username === "admin", "预期用户名是 admin");
});
%}

### [正常路径] 3. 正常登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

> {%
client.test("登出成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "业务码应该为 0");
});
%}

### [异常路径] 4. 登出后再次尝试获取当前用户，预期 401
GET {{baseUrl}}/api/auth/me

> {%
client.test("未登录阻断", function() {
    client.assert(response.status === 401, "登出后获取用户信息应该返回 401");
});
%}

### [异常路径] 5. 错误密码登录，预期 401
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}",
  "password": "{{wrongPassword}}"
}

> {%
client.test("密码错误阻断", function() {
    client.assert(response.status === 401, "密码错误应当返回 401");
    client.assert(response.body.code === 40002, "预期业务错误码 40002");
});
%}

### [异常路径] 6. 缺少 password 字段，预期 400
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{username}}"
}

> {%
client.test("参数缺失阻断", function() {
    client.assert(response.status === 400, "缺少密码应该返回 400");
    client.assert(response.body.code === 40001, "预期验证业务码 40001");
});
%}

### [异常路径] 7. 请求体不是 JSON 对象，预期 400
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

[
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
]

> {%
client.test("格式错误阻断", function() {
    client.assert(response.status === 400, "非对象 JSON 体应该返回 400");
});
%}


### 1. 用户 A 登录 (第 1 次，扣减令牌，预期 401)
< {%
  var o3 = Math.floor(Math.random() * 200) + 1;
  var o4 = Math.floor(Math.random() * 250) + 1;
  client.global.set("testIp", "192.168." + o3 + "." + o4);
%}
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{testIp}}

{
  "username": "user_limit_a",
  "password": "wrong_password_a"
}

> {%
client.test("第1次请求未限流", function() {
    client.assert(response.status === 401, "应返回密码错误 401");
});
%}

### 2. 用户 A 登录 (第 2 次，扣减令牌，预期 401)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{testIp}}

{
  "username": "user_limit_a",
  "password": "wrong_password_a"
}

> {%
client.test("第2次请求未限流", function() {
    client.assert(response.status === 401);
});
%}

