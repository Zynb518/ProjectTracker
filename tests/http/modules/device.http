  "purpose": "管理员调试打印周报"
}

> {%
client.test("管理员提交设备使用记录成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id > 0, "预期返回使用记录 ID");
    client.global.set("adminLogId", response.body.data.id);
});
%}

