### 给不存在设备提交使用记录，预期 404
POST {{baseUrl}}/api/devices/{{missingDeviceId}}/logs
Content-Type: application/json

{
  "purpose": "不存在设备使用记录测试"
}

> {%
client.test("给不存在设备提交使用记录返回 404", function() {
    client.assert(response.status === 404, "预期状态码 404");
    client.assert(response.body.code === 40407, "预期业务码 40407");
});
%}

### 8. 管理员查看设备使用记录
GET {{baseUrl}}/api/devices/{{adminDeviceId}}/logs?page=1&page_size=10

> {%
client.test("管理员查看设备使用记录成功", function() {
    var adminLogId = parseInt(client.global.get("adminLogId"));
    var exists = response.body.data.list.some(function(item) {
        return item.id === adminLogId && item.device_id === parseInt(client.global.get("adminDeviceId"));
    });

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.total >= 1, "预期至少 1 条使用记录");
    client.assert(exists, "使用记录列表应包含管理员刚提交的记录");
});
%}

