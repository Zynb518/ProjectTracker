    client.assert(response.body.code === 40001, "预期业务码 40001");
});
%}

### description 类型错误，预期 400
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "name": "invalid_description_device",
  "description": 123
}

> {%
client.test("description 非字符串返回 400", function() {
    client.assert(response.status === 400, "预期状态码 400");
    client.assert(response.body.code === 40001, "预期业务码 40001");
});
%}

### 请求体不是 JSON 对象，预期 400
POST {{baseUrl}}/api/devices
Content-Type: application/json

[
  {
    "name": "invalid_body_device"
  }
]

> {%
client.test("非对象 JSON 请求体返回 400", function() {
    client.assert(response.status === 400, "预期状态码 400");
    client.assert(response.body.code === 40001, "预期业务码 40001");
});
%}

### 6. 查询设备列表
GET {{baseUrl}}/api/devices?page=1&page_size=200

> {%
client.test("获取设备列表成功并限制 page_size 上限", function() {
    var adminDeviceId = parseInt(client.global.get("adminDeviceId"));
    var exists = response.body.data.list.some(function(item) {
        return item.id === adminDeviceId;
    });

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.page === 1, "预期 page 为 1");
    client.assert(response.body.data.page_size === 100, "page_size 超过 100 时应被限制为 100");
    client.assert(exists, "设备列表应包含刚创建的管理员设备");
});
%}

### page 非正整数，预期 400
GET {{baseUrl}}/api/devices?page=0&page_size=10

> {%
client.test("page 非正整数返回 400", function() {
    client.assert(response.status === 400, "预期状态码 400");
    client.assert(response.body.code === 40001, "预期业务码 40001");
});
%}

### page_size 非整数，预期 400
GET {{baseUrl}}/api/devices?page=1&page_size=abc

> {%
client.test("page_size 非整数返回 400", function() {
    client.assert(response.status === 400, "预期状态码 400");
    client.assert(response.body.code === 40001, "预期业务码 40001");
});
%}

### 7. 管理员提交设备使用记录
