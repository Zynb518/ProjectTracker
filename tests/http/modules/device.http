@baseUrl = http://127.0.0.1
@adminUsername = admin
@managerUsername = li_ming
@employeeUsername = chen_xu
@password = 123456
@missingDeviceId = 999999999999

### 1. 清理登录态
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

> {%
client.test("清理登录态成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
});
%}

### 2. 未登录访问设备列表被拦截
GET {{baseUrl}}/api/devices

> {%
client.test("未登录访问设备列表返回 401", function() {
    client.assert(response.status === 401, "预期状态码 401");
    client.assert(response.body.code === 40003, "预期业务码 40003");
});
%}

### 3. 管理员登录
< {%
  var o3 = Math.floor(Math.random() * 200) + 1;
  var o4 = Math.floor(Math.random() * 250) + 1;
  request.variables.set("loginIp", "172.16." + o3 + "." + o4);
%}
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{loginIp}}

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

> {%
client.test("管理员登录成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.user.system_role === 1, "预期管理员角色");
});
%}

### 4. 管理员创建设备
< {%
  var rand = Date.now() + "_" + Math.floor(Math.random() * 1000000);
  request.variables.set("adminDeviceName", "admin_device_" + rand);
%}
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "name": "{{adminDeviceName}}",
  "description": "设备模块管理员创建测试"
}

> {%
client.test("管理员创建设备成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id > 0, "预期返回设备 ID");
    client.global.set("adminDeviceId", response.body.data.id);
});
%}

### 5. 创建设备参数校验
### 缺少 name，预期 400
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "description": "缺少名称测试"
}

> {%
client.test("缺少 name 返回 400", function() {
    client.assert(response.status === 400, "预期状态码 400");
    client.assert(response.body.code === 40001, "预期业务码 40001");
});
%}

### name 为空字符串，预期 400
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "name": "",
  "description": "空名称测试"
}

> {%
client.test("空 name 返回 400", function() {
