### 10. 负责人候选人与负责人转交
GET {{baseUrl}}/api/projects/{{adminProjectId}}/owner/candidates?keyword=wang&page=1&page_size=10

> {%
client.test("管理员获取负责人转交候选人成功", function() {
    var wangCandidate = null;
    for (var i = 0; i < response.body.data.list.length; i++) {
        if (response.body.data.list[i].username === "wang_jie") {
            wangCandidate = response.body.data.list[i];
            break;
        }
    }

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(wangCandidate !== null, "候选人列表应包含 wang_jie");
    client.assert(wangCandidate.system_role === 2, "wang_jie 应为项目经理");
    client.global.set("wangJieUserId", wangCandidate.id);
});
%}

