### 8. 查询项目详情与列表
GET {{baseUrl}}/api/projects/{{adminProjectId}}

> {%
client.test("管理员获取项目详情成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id === parseInt(client.global.get("adminProjectId")), "项目 ID 应匹配");
    client.assert(response.body.data.permissions.can_edit_basic === true, "管理员应可编辑未完成项目");
    client.assert(response.body.data.permissions.can_delete === true, "管理员应可删除项目");
});
%}

