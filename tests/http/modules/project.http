@baseUrl = http://127.0.0.1
@adminUsername = admin
@managerUsername = wang_jie
@employeeUsername = chen_xu
@password = 123456
@missingProjectId = 999999999999
@missingUserId = 999999999999

### 1. 清理登录态
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

> {%
client.test("清理登录态成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
});
%}

### 2. 未登录访问项目列表被拦截
GET {{baseUrl}}/api/projects

> {%
client.test("未登录访问项目列表返回 401", function() {
    client.assert(response.status === 401, "预期状态码 401");
    client.assert(response.body.code === 40003, "预期业务码 40003");
});
%}

### 3. 普通员工登录并创建个人项目
< {%
  var o3 = Math.floor(Math.random() * 200) + 1;
  var o4 = Math.floor(Math.random() * 250) + 1;
  request.variables.set("loginIp", "172.40." + o3 + "." + o4);
%}
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{loginIp}}

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

> {%
client.test("普通员工登录成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.user.system_role === 3, "预期普通员工角色");
    client.global.set("employeeUserId", response.body.data.user.id);
});
%}

### 普通员工创建个人项目
< {%
  var rand = Date.now() + "_" + Math.floor(Math.random() * 1000000);
  request.variables.set("employeeProjectName", "employee_project_" + rand);
%}
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{employeeProjectName}}",
  "description": "普通员工个人项目测试",
  "planned_start_date": "2026-12-01",
  "planned_end_date": "2026-12-31"
}

> {%
client.test("普通员工创建个人项目成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id > 0, "预期返回项目 ID");
    client.assert(response.body.data.owner_user_id === parseInt(client.global.get("employeeUserId")), "个人项目负责人应为创建人");
    client.global.set("employeeProjectId", response.body.data.id);
});
%}

### 4. 普通员工登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

> {%
client.test("普通员工登出成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
});
%}

### 5. 管理员登录
< {%
  var o3 = Math.floor(Math.random() * 200) + 1;
  var o4 = Math.floor(Math.random() * 250) + 1;
  request.variables.set("loginIp", "172.41." + o3 + "." + o4);
%}
# @name adminLogin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json
x-forwarded-for: {{loginIp}}

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

> {%
client.test("管理员登录成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.user.system_role === 1, "预期管理员角色");
    client.global.set("adminUserId", response.body.data.user.id);
});
%}

### 6. 管理员创建项目
< {%
  var rand = Date.now() + "_" + Math.floor(Math.random() * 1000000);
  request.variables.set("adminProjectName", "admin_project_" + rand);
%}
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{adminProjectName}}",
  "description": "项目模块管理员创建测试",
  "planned_start_date": "2026-12-01",
  "planned_end_date": "2026-12-31"
}

> {%
client.test("管理员创建项目成功", function() {
    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.id > 0, "预期返回项目 ID");
    client.assert(response.body.data.owner_user_id === parseInt(client.global.get("adminUserId")), "项目负责人应为管理员");
    client.assert(response.body.data.status === 1, "新项目状态应为未开始");
    client.global.set("adminProjectId", response.body.data.id);
});
%}

