### 获取项目列表
GET {{baseUrl}}/api/projects?page=1&page_size=10

> {%
client.test("管理员获取项目列表成功", function() {
    var adminProjectId = parseInt(client.global.get("adminProjectId"));
    var exists = response.body.data.list.some(function(item) {
        return item.id === adminProjectId;
    });

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(response.body.data.page === 1, "预期 page 为 1");
    client.assert(response.body.data.page_size === 10, "预期 page_size 为 10");
    client.assert(exists, "项目列表应包含管理员刚创建的项目");
});
%}

### 按状态与关键字筛选项目列表
GET {{baseUrl}}/api/projects?keyword=admin_project_&status=1&page=1&page_size=10

> {%
client.test("管理员按状态与关键字筛选项目列表成功", function() {
    var adminProjectId = parseInt(client.global.get("adminProjectId"));
    var exists = response.body.data.list.some(function(item) {
        return item.id === adminProjectId && item.status === 1;
    });

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(exists, "筛选结果应包含未开始的管理员测试项目");
});
%}

### 管理员按负责人筛选项目列表
GET {{baseUrl}}/api/projects?owner_user_id={{adminUserId}}&page=1&page_size=10

> {%
client.test("管理员按负责人筛选项目列表成功", function() {
    var adminUserId = parseInt(client.global.get("adminUserId"));
    var adminProjectId = parseInt(client.global.get("adminProjectId"));
    var exists = response.body.data.list.some(function(item) {
        return item.id === adminProjectId && item.owner_user_id === adminUserId;
    });

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(exists, "负责人筛选结果应包含管理员测试项目");
});
%}

