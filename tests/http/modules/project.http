### 16. 普通员工权限校验
GET {{baseUrl}}/api/projects?page=1&page_size=20

> {%
client.test("普通员工只能在列表中看到有权限的项目", function() {
    var adminProjectId = parseInt(client.global.get("adminProjectId"));
    var employeeProjectId = parseInt(client.global.get("employeeProjectId"));
    var containsAdminProject = response.body.data.list.some(function(item) {
        return item.id === adminProjectId;
    });
    var containsEmployeeProject = response.body.data.list.some(function(item) {
        return item.id === employeeProjectId;
    });

    client.assert(response.status === 200, "预期状态码 200");
    client.assert(response.body.code === 0, "预期业务码 0");
    client.assert(containsEmployeeProject, "普通员工应能看到自己的个人项目");
    client.assert(!containsAdminProject, "普通员工不应在列表中看到非成员项目");
});
%}

