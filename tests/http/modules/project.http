client.test("获取甘特图节点成功", function() {
    client.assert(response.status === 200);
});
%}

### 获取甘特图成员/时间数据
GET {{baseUrl}}/api/projects/{{newProjectId}}/gantt/members

> {%
client.test("获取甘特图成员成功", function() {
    client.assert(response.status === 200);
});
%}

### ==========================================
### 8. 权限边界与越权测试
### ==========================================
### 管理员登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 普通员工登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

### 越权尝试：普通员工不能删除非本人负责项目，预期 403
DELETE {{baseUrl}}/api/projects/{{newProjectId}}

> {%
client.test("越权删除项目被拦截", function() {
    client.assert(response.status === 403);
});
%}

### 普通员工登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### ==========================================
### 9. 数据闭环清理 (删除项目保证幂等性)
### ==========================================
### 重新登录管理员
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 删除创建的新项目
DELETE {{baseUrl}}/api/projects/{{newProjectId}}

> {%
client.test("删除项目成功，环境清理完毕", function() {
    client.assert(response.status === 200);
});
%}
