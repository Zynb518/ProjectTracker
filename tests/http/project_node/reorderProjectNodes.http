POST {{baseUrl}}/api/projects/{{repeatablePersonalReorderProjectId}}/nodes
Content-Type: application/json

{
  "name": "个人节点二",
  "planned_start_date": "2026-04-05",
  "planned_end_date": "2026-04-08"
}

