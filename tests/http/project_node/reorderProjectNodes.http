POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{ownerUsername}}",
  "password": "{{password}}"
}

### 正常路径：项目负责人创建临时项目
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{repeatableOwnerReorderProjectName}}",
  "description": "用于验证项目负责人调整阶段节点顺序接口。",
  "planned_start_date": "2026-04-01",
  "planned_end_date": "2026-04-30"
}

> {% client.global.set("repeatableOwnerReorderProjectId", response.body.data.id); %}

### 正常路径：项目负责人创建第一个阶段节点
POST {{baseUrl}}/api/projects/{{repeatableOwnerReorderProjectId}}/nodes
Content-Type: application/json

{
  "name": "需求分析",
  "planned_start_date": "2026-04-03",
  "planned_end_date": "2026-04-07"
}

> {% client.global.set("repeatableOwnerReorderNodeId1", response.body.data.id); %}

### 正常路径：项目负责人创建第二个阶段节点
POST {{baseUrl}}/api/projects/{{repeatableOwnerReorderProjectId}}/nodes
Content-Type: application/json

{
  "name": "联调测试",
  "planned_start_date": "2026-04-08",
  "planned_end_date": "2026-04-12"
}

> {% client.global.set("repeatableOwnerReorderNodeId2", response.body.data.id); %}

### 正常路径：项目负责人调整自己项目下的阶段节点顺序
PUT {{baseUrl}}/api/projects/{{repeatableOwnerReorderProjectId}}/nodes/reorder
Content-Type: application/json

{
  "nodes": [
    {
      "node_id": {{repeatableOwnerReorderNodeId2}},
      "sequence_no": 1
    },
    {
      "node_id": {{repeatableOwnerReorderNodeId1}},
      "sequence_no": 2
    }
  ]
}

### 正常路径：项目负责人登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 正常路径：普通员工登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

### 正常路径：普通员工创建个人自用临时项目
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{repeatablePersonalReorderProjectName}}",
  "description": "用于验证普通员工个人自用项目的重排权限。",
  "planned_start_date": "2026-04-01",
  "planned_end_date": "2026-04-30"
}

> {% client.global.set("repeatablePersonalReorderProjectId", response.body.data.id); %}

### 正常路径：普通员工为个人自用项目创建第一个阶段节点
POST {{baseUrl}}/api/projects/{{repeatablePersonalReorderProjectId}}/nodes
Content-Type: application/json

{
  "name": "个人节点一",
  "planned_start_date": "2026-04-02",
  "planned_end_date": "2026-04-04"
}

> {% client.global.set("repeatablePersonalReorderNodeId1", response.body.data.id); %}

