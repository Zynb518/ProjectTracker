  "planned_start_date": "2026-04-01",
  "planned_end_date": "2099-12-31"
}

> {% client.global.set("repeatableEmployeeReopenNodeProjectId", response.body.data.id); %}

### 正常路径：普通员工创建个人项目下的临时阶段节点
POST {{baseUrl}}/api/projects/{{repeatableEmployeeReopenNodeProjectId}}/nodes
Content-Type: application/json

{
  "name": "个人返工",
  "description": "用于验证普通员工项目负责人可撤销自己的节点完成。",
  "planned_start_date": "2026-04-02",
  "planned_end_date": "2099-12-20"
}

> {% client.global.set("repeatableEmployeeReopenNodeId", response.body.data.id); %}

### 正常路径：普通员工先完成自己的阶段节点
POST {{baseUrl}}/api/projects/{{repeatableEmployeeReopenNodeProjectId}}/nodes/{{repeatableEmployeeReopenNodeId}}/complete
Content-Type: application/json

{}

