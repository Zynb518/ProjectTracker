  "planned_start_date": "2026-04-01",
  "planned_end_date": "2099-12-31"
}

> {% client.global.set("repeatableEmployeeStartNodeProjectId", response.body.data.id); %}

### 正常路径：普通员工创建个人项目下的无子任务临时阶段节点
POST {{baseUrl}}/api/projects/{{repeatableEmployeeStartNodeProjectId}}/nodes
Content-Type: application/json

{
  "name": "个人推进",
  "description": "用于验证普通员工项目负责人可手动开始自己的节点。",
  "planned_start_date": "2026-04-02",
  "planned_end_date": "2099-12-20"
}

> {% client.global.set("repeatableEmployeeStartNodeId", response.body.data.id); %}

### 正常路径：普通员工手动开始自己项目下的阶段节点，预期 status=2
POST {{baseUrl}}/api/projects/{{repeatableEmployeeStartNodeProjectId}}/nodes/{{repeatableEmployeeStartNodeId}}/start
Content-Type: application/json

{}

