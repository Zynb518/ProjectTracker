@baseUrl = http://127.0.0.1:8080
@adminUsername = admin
@employeeUsername = chen_xu
@password = 123456
@deviceName = 测试打印机

### 正常路径：管理员登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 正常路径：创建设备
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "name": "{{deviceName}}",
  "description": "用于验证创建设备接口"
}

### 异常路径：缺少 name，预期 400
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "description": "缺少名称测试"
}

### 正常路径：管理员登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 异常路径：未登录创建设备，预期 401
POST {{baseUrl}}/api/devices
Content-Type: application/json

{
  "name": "unauthorized_device_case",
  "description": "未登录创建设备测试"
}
