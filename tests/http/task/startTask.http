@baseUrl = http://127.0.0.1:8080
@adminUsername = admin
@employeeUsername = chen_xu
@password = 123456
@candidateMemberUserId = 3
@repeatableAdminStartTaskProjectName = start_task_admin_case_{{$timestamp}}
@repeatableEmployeeStartTaskProjectName = start_task_employee_case_{{$timestamp}}
@completedTaskId = 3
@missingTaskId = 999999
@invalidTaskId = 0

### 提示：正常路径会先创建临时项目、临时阶段节点、临时子任务，因此可以重复回放。
### 提示：当前固定 completedTaskId=3 用于验证“已完成子任务不能直接手动开始”。
### 当前为 13.7 手动开始子任务 的 RED 用例；接口未实现前，相关请求会先失败，后续据此补实现。

### 正常路径：管理员登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 正常路径：管理员创建临时项目
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{repeatableAdminStartTaskProjectName}}",
  "description": "用于验证管理员手动开始子任务接口。",
  "planned_start_date": "2026-04-01",
  "planned_end_date": "2099-12-31"
}

> {% client.global.set("repeatableAdminStartTaskProjectId", response.body.data.id); %}

### 正常路径：管理员创建临时阶段节点
POST {{baseUrl}}/api/projects/{{repeatableAdminStartTaskProjectId}}/nodes
Content-Type: application/json

{
  "name": "联调准备",
  "description": "用于验证管理员手动开始子任务。",
  "planned_start_date": "2026-04-02",
  "planned_end_date": "2099-12-20"
}

> {% client.global.set("repeatableAdminStartTaskNodeId", response.body.data.id); %}

### 正常路径：管理员为项目添加成员 wang_jie
POST {{baseUrl}}/api/projects/{{repeatableAdminStartTaskProjectId}}/members
Content-Type: application/json

{
  "user_id": {{candidateMemberUserId}}
}

### 正常路径：管理员创建一个未逾期的临时子任务
POST {{baseUrl}}/api/projects/{{repeatableAdminStartTaskProjectId}}/nodes/{{repeatableAdminStartTaskNodeId}}/subtasks
Content-Type: application/json

{
  "name": "接口联调",
  "description": "用于验证管理员手动开始子任务。",
  "responsible_user_id": {{candidateMemberUserId}},
  "planned_start_date": "2026-04-06",
  "planned_end_date": "2099-12-10"
}

> {% client.global.set("repeatableAdminStartTaskId", response.body.data.id); %}

### 正常路径：管理员手动开始子任务，传空字符串时应回填默认 progress_note
POST {{baseUrl}}/api/subtasks/{{repeatableAdminStartTaskId}}/start
Content-Type: application/json

{
  "progress_note": ""
}

> {%
client.test("管理员手动开始子任务成功并回填默认开始说明", function() {
  client.assert(response.status === 200, "手动开始子任务应返回 200");
  client.assert(response.body.code === 0, "响应 code 应为 0");
  client.assert(response.body.data.subtask.id === client.global.get("repeatableAdminStartTaskId"), "返回的 subtask.id 应等于目标子任务");
  client.assert(response.body.data.subtask.status === 2, "未逾期子任务手动开始后 status 应为 2");
  client.assert(response.body.data.subtask.progress_percent === 0, "progress_percent 应保持为 0");
  client.assert(response.body.data.subtask.completed_at === null, "completed_at 应为 null");
  client.assert(response.body.data.progress_record.sub_task_id === client.global.get("repeatableAdminStartTaskId"), "progress_record.sub_task_id 应等于目标子任务");
  client.assert(response.body.data.progress_record.progress_note === "开始处理该任务", "空字符串应回填默认开始说明");
  client.assert(response.body.data.progress_record.progress_percent === 0, "开始记录的 progress_percent 应为 0");
  client.assert(response.body.data.progress_record.status === 2, "未逾期子任务开始记录 status 应为 2");
});
%}

### 正常路径：管理员登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 正常路径：普通员工登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{employeeUsername}}",
  "password": "{{password}}"
}

### 正常路径：普通员工创建临时个人项目
POST {{baseUrl}}/api/projects
Content-Type: application/json

{
  "name": "{{repeatableEmployeeStartTaskProjectName}}",
  "description": "用于验证负责人手动开始自己负责的子任务。",
  "planned_start_date": "2026-04-01",
  "planned_end_date": "2099-12-31"
}

> {% client.global.set("repeatableEmployeeStartTaskProjectId", response.body.data.id); %}

### 正常路径：普通员工创建临时阶段节点
POST {{baseUrl}}/api/projects/{{repeatableEmployeeStartTaskProjectId}}/nodes
Content-Type: application/json

{
  "name": "个人推进",
  "description": "用于验证负责人手动开始自己负责的子任务。",
  "planned_start_date": "2026-04-02",
  "planned_end_date": "2099-12-20"
}

> {% client.global.set("repeatableEmployeeStartTaskNodeId", response.body.data.id); %}

### 正常路径：普通员工创建自己负责的临时子任务
POST {{baseUrl}}/api/projects/{{repeatableEmployeeStartTaskProjectId}}/nodes/{{repeatableEmployeeStartTaskNodeId}}/subtasks
Content-Type: application/json

{
  "name": "个人待办",
  "description": "用于验证负责人手动开始自己的子任务。",
  "planned_start_date": "2026-04-06",
  "planned_end_date": "2099-12-10"
}

> {% client.global.set("repeatableEmployeeStartTaskId", response.body.data.id); %}

### 正常路径：普通员工手动开始自己负责的子任务
POST {{baseUrl}}/api/subtasks/{{repeatableEmployeeStartTaskId}}/start
Content-Type: application/json

{
  "progress_note": "开始跟进个人任务"
}

### 正常路径：普通员工登出
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}

### 异常路径：未登录手动开始子任务，预期 401
POST {{baseUrl}}/api/subtasks/{{repeatableAdminStartTaskId}}/start
Content-Type: application/json

{}

### 异常路径：重新登录管理员
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 异常路径：管理员不能开始普通员工创建的个人自用项目子任务，预期 403
POST {{baseUrl}}/api/subtasks/{{repeatableEmployeeStartTaskId}}/start
Content-Type: application/json

{}

### 异常路径：管理员开始不存在的子任务，预期 404
POST {{baseUrl}}/api/subtasks/{{missingTaskId}}/start
Content-Type: application/json

{}

### 异常路径：管理员开始已完成子任务，预期 409
POST {{baseUrl}}/api/subtasks/{{completedTaskId}}/start
Content-Type: application/json

{}
