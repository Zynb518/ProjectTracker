POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{devUsername}}",
  "password": "{{password}}"
}

> {%
client.test("开发人员登录成功", function() {
    client.assert(response.status === 200);
});
%}

### 开始处理子任务 2 (物理表设计与API规范)
POST {{baseUrl}}/api/subtasks/{{taskId2}}/start
Content-Type: application/json

{
  "progress_note": "开始数据库建模"
}

> {%
client.test("开始子任务2成功", function() {
    client.assert(response.status === 200);
});
%}

### 提交子任务 2 完成
POST {{baseUrl}}/api/subtasks/{{taskId2}}/progress
Content-Type: application/json

{
  "progress_percent": 100,
  "progress_note": "完成SQL物理表模型构建与Swagger契约导出"
}

> {%
client.test("表设计子任务已闭环完成", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.subtask.status === 3);
});
%}

### 开发人员退出登录
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}


### ==========================================================================
### 4. 项目经理登录，确认当前阶段全部子任务完成，将该阶段节点标志为已完结
### ==========================================================================

### 项目经理登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{pmUsername}}",
  "password": "{{password}}"
}

> {%
client.test("项目经理二次登录成功", function() {
    client.assert(response.status === 200);
});
%}

### 完成阶段节点 1 (由于其下的两个子任务都已完成，节点符合完结条件)
POST {{baseUrl}}/api/projects/{{pmUsername}}/nodes/{{nodeId1}}/complete
Content-Type: application/json

{}

> {%
client.test("阶段节点1完结成功", function() {
    client.assert(response.status === 200);
    client.assert(response.body.data.status === 3);
});
%}

### 项目经理退出登录
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{}


### ==========================================================================
### 5. 管理员登录并执行数据闭环清理 (保证环境零依赖、零残留，维持幂等性)
### ==========================================================================

### 管理员重新登录
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "{{password}}"
}

### 级联删除该项目 (同时级联清空其下的关联成员、阶段节点、子任务以及历史操作明细记录)
DELETE {{baseUrl}}/api/projects/{{projId}}

> {%
client.test("级联物理清空该项目成功，全量链路演示闭环完毕，测试前后数据库保持无污染", function() {
    client.assert(response.status === 200);
});
%}
